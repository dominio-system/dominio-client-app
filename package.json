{
  "name": "dominio-system",
  "productName": "Dominio System",
  "version": "2.3.16",
  "description": "Dashboard de rendimiento para clientes de Dominio System",
  "main": "main.js",
  "author": {
    "name": "Dominio System",
    "email": "hola@dominiosystem.com"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "@sentry/electron": "^7.11.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.dominio.client",
    "productName": "Dominio System",
    "copyright": "© 2026 Dominio System",
    "icon": "assets/icon",
    "artifactName": "Dominio-${version}-${arch}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "login.html",
      "dashboard.html",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSCameraUsageDescription": "Dominio System necesita acceso a la cámara para capturar tu foto de perfil desde Configuración → Negocio.",
        "NSMicrophoneUsageDescription": "Dominio System puede solicitar acceso al micrófono junto con la cámara durante la captura de la foto de perfil. No se graba audio."
      }
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://dominiosystem.com/updates/mac",
        "channel": "latest"
      }
    ],
    "dmg": {
      "title": "Dominio System",
      "backgroundColor": "#0c0c0c",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Dominio System"
    }
  }
}
